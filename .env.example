# Copia este archivo a .env (en la misma carpeta que docker-compose.yml)
# y cambia al menos POSTGRES_PASSWORD. .env NUNCA debe subirse al repositorio.

POSTGRES_DB=data_service_db
POSTGRES_USER=data_service_app
POSTGRES_PASSWORD=cambia_esta_password

DEFAULT_START_DATE=2005-01-01
PIPELINE_VERSION=v1
