# Copia este archivo a .env y completa los valores reales.
# .env NUNCA debe subirse al repositorio (ver .gitignore).

# --- Base de datos (PostgreSQL + TimescaleDB) ---------------------------
# Formato: postgresql://usuario:password@host:puerto/nombre_base
DATABASE_URL=postgresql://data_service_app:CHANGE_ME@localhost:5432/data_service_db

# --- Pipeline -------------------------------------------------------------
# Fecha desde la que se descarga histórico si un ticker no tiene datos
# todavía en raw_ohlc (primera carga).
DEFAULT_START_DATE=2005-01-01

# Identificador de versión de este pipeline (commit/tag de git),
# inyectado idealmente por CI/CD. Se guarda en ingestion_log.pipeline_version.
PIPELINE_VERSION=unknown

# --- Logging (opcional) ----------------------------------------------------
# Si no se define, se usa <raíz_del_repo>/logs/data_service
# DATA_SERVICE_LOG_DIR=/var/log/data_service
